# OpenRouter Configuration
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Optional comma-separated free fallbacks. Built-in fallbacks are used when empty.
OPENROUTER_FALLBACK_MODELS=
LLM_REQUEST_TIMEOUT_MS=25000

# Local dashboard (binds to 127.0.0.1)
DASHBOARD_PORT=3000

# Mem0 Configuration
MEM0_API_KEY=

# NeonDB Configuration
DATABASE_URL=

# Telegram Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# CRON Schedule (e.g. daily at 9am server time: 0 9 * * *)
CRON_SCHEDULE="0 9 * * *"

# GitHub Configuration
# Private repositories require classic `repo` scope or equivalent fine-grained read access.
GITHUB_TOKEN=
GITHUB_USERNAME=
